# Required (create bot via @BotFather)
BOT_TOKEN=123456:ABCDEF-your-bot-token

# Required: private channel/group to store config (bot must be admin there)
DB_CHAT=@my_private_db_channel

# Recommended: lock bot to your Telegram user id (send /myid to the bot)
OWNER_ID=123456789

# Recommended on servers
NON_INTERACTIVE=1

# Render Web Service webhook (recommended on Render)
# WEBHOOK_BASE_URL=https://your-service.onrender.com

# Telethon FloodWait: if Telegram rate-limits, relay retries after this wait.
# Lower means you'll get errors faster; higher means it'll "sleep" more automatically.
FLOOD_SLEEP_THRESHOLD=60
