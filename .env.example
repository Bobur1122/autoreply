# Telegram API credentials (get them from https://my.telegram.org)
TG_API_ID=123456
TG_API_HASH=0123456789abcdef0123456789abcdef

# Session file name (a .session file will be created next to this project)
TG_SESSION=userbot

# Alternative to TG_SESSION file (recommended for servers with read-only disk):
# Generate it locally with: python export_session_string.py
# TG_SESSION_STRING=YOUR_STRING_SESSION

# Optional (if you don't set these, the script will ask on first run)
TG_PHONE=+998901234567
# TG_PASSWORD=your_2fa_password

# Optional (use on servers to fail fast if login is required)
# NON_INTERACTIVE=1

# Source channel(s) to read from (comma-separated). Examples:
# SOURCE_CHATS=@sourcechannel1,-1001234567890
SOURCE_CHATS=@sourcechannel1

# Destination channel/chat to post into. Examples:
# DEST_CHAT=@destchannel
DEST_CHAT=@destchannel

# What to replace sensitive items with
REPLACE_LINK_WITH=[removed_link]
REPLACE_PHONE_WITH=[removed_phone]
REPLACE_USERNAME_WITH=@removed_username

# Optional
# DRY_RUN=1
